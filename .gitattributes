# Normalize line endings to LF for all text files (default).
# Without this, contributors on Windows can silently commit CRLF
# in shell scripts and break the `#!/bin/bash` interpreter line.
* text=auto eol=lf

# Explicit text files — pin LF even when Git's auto-detection is unsure.
*.sh           text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.json         text eol=lf
*.toml         text eol=lf
*.ini          text eol=lf
*.conf         text eol=lf
*.txt          text eol=lf
LICENSE        text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# Binary files — skip line-ending conversion and Git's text diff.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  binary
*.gz   binary
*.zip  binary
*.tar  binary
*.tgz  binary

# Treat lockfiles as generated (suppress noisy diffs).
package-lock.json linguist-generated=true
yarn.lock         linguist-generated=true
pnpm-lock.yaml    linguist-generated=true

# GitHub Linguist hints — these are workflow/automation scripts, not
# the primary "language" of the repo.
.github/** linguist-vendored

